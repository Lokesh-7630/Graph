#include<iostream>
#include<queue>
#include<list>
#include<vector>
using namespace std;
class Graph{
int V;
list<int>*l;

public:
Graph(int V){
    this->V=V;
    l=new list<int>[V];
}
void addEdge(int u,int v){
   l[u].push_back(v);
   
}
void pathHelper(vector<bool>&vis,string &path,int src,int dst){
    if(src==dst){
        cout<<path<<dst<<endl;
        return;
    }
    vis[src]=true;
    path+=to_string(src);
    list<int>neighbour=l[src];
    for(int v:neighbour){
        if(!vis[v]){
            pathHelper(vis,path,v,dst);
        }
    }
    path=path.substr(0,path.size()-1);
    vis[src]=false;
}
void AllPath(int src,int dst){
    vector<bool>vis(V,false);
    string path="";
    pathHelper(vis,path,src,dst);
}


};
int main(){
Graph graph(6);
 graph.addEdge(0,3);
 graph.addEdge(4,0);
 graph.addEdge(5,0);
 graph.addEdge(5,2);
 graph.addEdge(2,3);
 graph.addEdge(3,1);
 graph.addEdge(4,1);

 graph.AllPath(5,1);




    return 0;
}
