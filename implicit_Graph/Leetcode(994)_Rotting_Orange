class Solution {
public:
    int orangesRotting(vector<vector<int>>& grid) {
        int n=grid.size();
        int m=grid[0].size();
        int ans=0;
        queue<pair<pair<int,int>,int>>q;
        vector<vector<bool>>vis(n,vector<bool>(m,false));
        //pusing rotten orange
        for(int i=0; i<n; i++){
            for(int j=0; j<m; j++){
                if(grid[i][j]==2){
                    q.push({{i,j},0});
                    vis[i][j]=true;
                }
            }
        }
        //BFS
        while(q.size()>0){
        int i=q.front().first.first;
        int j=q.front().first.second;
        int t=q.front().second;
        q.pop();
        ans=max(ans,t);

        //UP
        if(i-1>=0 && grid[i-1][j]==1 && !vis[i-1][j]){
           q.push({{i-1,j},t+1});
           vis[i-1][j]=true;
        }
        //left
        if(j-1>=0 && grid[i][j-1]==1  && !vis[i][j-1]){
           q.push({{i,j-1},t+1});
           vis[i][j-1]=true;
        }
        //right
        if(j+1<m && grid[i][j+1]==1  && !vis[i][j+1]){
           q.push({{i,j+1},t+1});
           vis[i][j+1]=true;
        }
        //bottom
        if( i+1<n && grid[i+1][j]==1  && !vis[i+1][j]){
           q.push({{i+1,j},t+1});
           vis[i+1][j]=true;
        }

        }
        for(int i=0; i<n; i++){
            for(int j=0; j<m; j++){
                if(  grid[i][j]==1 && !vis[i][j]){
                    return -1;
                }
            }
        }
        return ans;
    }
};
